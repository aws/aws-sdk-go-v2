PUT /

Content-Type: application/xml
X-Amz-Acl: private
X-Amz-Bucket-Namespace: account-regional
X-Amz-Bucket-Object-Lock-Enabled: true
X-Amz-Grant-Full-Control: __GrantFullControl__
X-Amz-Grant-Read: __GrantRead__
X-Amz-Grant-Read-Acp: __GrantReadACP__
X-Amz-Grant-Write: __GrantWrite__
X-Amz-Grant-Write-Acp: __GrantWriteACP__
X-Amz-Object-Ownership: BucketOwnerPreferred

